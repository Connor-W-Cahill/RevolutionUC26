rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // === Users ===
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // === Readings (from Presage SDK) ===
    // Schema: { userID, timestamp, pulseRate, breathingRate,
    //           bloodPressurePhasic?, breathingAmplitude?,
    //           inhaleExhaleRatio?, apneaDetected? }
    match /readings/{readingId} {
      allow read: if request.auth != null && (
        resource.data.userID == request.auth.uid ||
        isFriend(request.auth.uid, resource.data.userID)
      );
      allow create: if request.auth != null
        && request.resource.data.userID == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.userID == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.userID == request.auth.uid;
    }

    // === Activities ===
    match /activities/{activityId} {
      allow read: if request.auth != null
        && resource.data.userID == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userID == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.userID == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.userID == request.auth.uid;
    }

    // === Friendships ===
    match /friendships/{friendshipId} {
      allow read: if request.auth != null && (
        resource.data.userA == request.auth.uid ||
        resource.data.userB == request.auth.uid
      );
      allow create: if request.auth != null && (
        request.resource.data.initiatedBy == request.auth.uid &&
        (request.resource.data.userA == request.auth.uid ||
         request.resource.data.userB == request.auth.uid)
      );
      allow update: if request.auth != null && (
        resource.data.userA == request.auth.uid ||
        resource.data.userB == request.auth.uid
      );
      allow delete: if false;
    }

    // === AI Tips (written by Cloud Functions, read-only for clients) ===
    match /aiTips/{tipId} {
      allow read: if request.auth != null
        && resource.data.userID == request.auth.uid;
      allow write: if false;
    }

    function isFriend(currentUser, otherUser) {
      let pair1 = /databases/$(database)/documents/friendships/$(currentUser + "_" + otherUser);
      let pair2 = /databases/$(database)/documents/friendships/$(otherUser + "_" + currentUser);
      return (
        (exists(pair1) && get(pair1).data.status == "accepted") ||
        (exists(pair2) && get(pair2).data.status == "accepted")
      );
    }
  }
}
