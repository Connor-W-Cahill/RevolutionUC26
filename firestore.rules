rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // === Users ===
    // Schema: { displayName, email, photoURL?, friendIDs[], sharingDefaults?, timezone?, createdAt }
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // === Readings ===
    // Schema: { userID, timestamp, stressLevel, heartRate, hrv, spO2, respiratoryRate, source?, isSpikeCandidate? }
    match /readings/{readingId} {
      allow read: if request.auth != null && (
        resource.data.userID == request.auth.uid ||
        isFriend(request.auth.uid, resource.data.userID) ||
        hasSharePermission(resource.data.userID, request.auth.uid, "latestStress")
      );
      allow create: if request.auth != null
        && request.resource.data.userID == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.userID == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.userID == request.auth.uid;
    }

    // === Activities ===
    // Schema: { userID, date (Timestamp), category, title, notes?, rating? }
    match /activities/{activityId} {
      allow read: if request.auth != null
        && resource.data.userID == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userID == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.userID == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.userID == request.auth.uid;
    }

    // === Friendships ===
    // Schema: { userA, userB, status ("pending"|"accepted"|"declined"), initiatedBy, createdAt, updatedAt }
    // userA is always the lexicographically smaller UID
    match /friendships/{friendshipId} {
      allow read: if request.auth != null && (
        resource.data.userA == request.auth.uid ||
        resource.data.userB == request.auth.uid
      );
      allow create: if request.auth != null && (
        request.resource.data.initiatedBy == request.auth.uid &&
        (request.resource.data.userA == request.auth.uid ||
         request.resource.data.userB == request.auth.uid)
      );
      allow update: if request.auth != null && (
        resource.data.userA == request.auth.uid ||
        resource.data.userB == request.auth.uid
      );
      allow delete: if false;
    }

    // === AI Tips (Cloud Functions write only) ===
    // Schema: { userID, tips: [...], generatedAt, basedOn: { readingCount, activityCount } }
    match /aiTips/{tipId} {
      allow read: if request.auth != null
        && resource.data.userID == request.auth.uid;
      allow write: if false;
    }

    // === Spike Events (Cloud Functions write only) ===
    // Schema: { id, userID, readingID, timestamp, stressLevel, baselineMean, baselineStdDev,
    //           delta, severity, triggerReason, createdAt }
    match /spikeEvents/{spikeId} {
      allow read: if request.auth != null
        && resource.data.userID == request.auth.uid;
      allow write: if false;
    }

    // === Streaks (Cloud Functions write only) ===
    // Schema: { userID, currentReadingStreak, bestReadingStreak, lastReadingDate,
    //           currentActivityStreak, bestActivityStreak, lastActivityDate, updatedAt }
    match /streaks/{userId} {
      allow read: if request.auth != null
        && request.auth.uid == userId;
      allow write: if false;
    }

    // === Groups ===
    // Schema: { id, name, ownerID, memberIDs[], createdAt, updatedAt, visibility }
    match /groups/{groupId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.memberIDs;
      allow create: if request.auth != null
        && request.resource.data.ownerID == request.auth.uid
        && request.auth.uid in request.resource.data.memberIDs;
      allow update: if request.auth != null
        && resource.data.ownerID == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.ownerID == request.auth.uid;
    }

    // === Group Daily Stats (Cloud Functions write only) ===
    // Schema: { id, groupID, date, memberCount, activeMemberCount, avgStress, minStress, maxStress, updatedAt }
    match /groupDailyStats/{statId} {
      allow read: if request.auth != null
        && isGroupMember(resource.data.groupID);
      allow write: if false;
    }

    // === Shares ===
    // Schema: { id, ownerID, viewerID, status, permissions: { latestStress, history, groupStats },
    //           createdAt, updatedAt }
    // Document ID format: ownerID_viewerID
    match /shares/{shareId} {
      allow read: if request.auth != null && (
        resource.data.ownerID == request.auth.uid ||
        resource.data.viewerID == request.auth.uid
      );
      allow create: if request.auth != null
        && request.resource.data.ownerID == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.ownerID == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.ownerID == request.auth.uid;
    }

    // ─── Helper Functions ───────────────────────────────────────────────────

    function isFriend(currentUser, otherUser) {
      let pair1 = /databases/$(database)/documents/friendships/$(currentUser + "_" + otherUser);
      let pair2 = /databases/$(database)/documents/friendships/$(otherUser + "_" + currentUser);
      return (
        (exists(pair1) && get(pair1).data.status == "accepted") ||
        (exists(pair2) && get(pair2).data.status == "accepted")
      );
    }

    function hasSharePermission(ownerID, viewerID, permissionField) {
      let shareDoc = /databases/$(database)/documents/shares/$(ownerID + "_" + viewerID);
      return exists(shareDoc)
        && get(shareDoc).data.status == "active"
        && get(shareDoc).data.permissions[permissionField] == true;
    }

    function isGroupMember(groupID) {
      let groupDoc = /databases/$(database)/documents/groups/$(groupID);
      return exists(groupDoc) && request.auth.uid in get(groupDoc).data.memberIDs;
    }
  }
}
