# Firebase project config (these go in GoogleService-Info.plist for iOS)
# Get from Firebase Console > Project Settings
FIREBASE_PROJECT_ID=cortisol-tracker-revuc26

# Anthropic API key (set as Firebase secret, NOT in .env)
# Run: firebase functions:secrets:set ANTHROPIC_API_KEY
# ANTHROPIC_API_KEY=sk-ant-...

# Presage SmartSpectra SDK key (for iOS app)
# Get from https://docs.physiology.presagetech.com/
# PRESAGE_API_KEY=...
